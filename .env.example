# ── Les Jardins de l'Hacienda — Variables d'environnement ──────────────────
# Copier ce fichier en .env.local et remplir toutes les valeurs avant le déploiement

# ── URL DE PRODUCTION ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.lesjardinsdelhacienda54.com

# ── TÉLÉPHONE (public) ──────────────────────────────────────────────────────
# Utilisé dans FloatingCTA pour le bouton d'appel / WhatsApp
NEXT_PUBLIC_PHONE=0609386764

# ── EMAILS ──────────────────────────────────────────────────────────────────
# Adresse de réception des formulaires (contact, réceptions, newsletter, liste d'attente)
CONTACT_EMAIL=contact@lesjardinsdelhacienda54.com

# Adresse d'expédition — doit être un domaine vérifié dans Resend
FROM_EMAIL=noreply@lesjardinsdelhacienda54.com

# ── RESEND (envoi d'emails transactionnels) ─────────────────────────────────
# Gratuit jusqu'à 3 000 emails/mois — https://resend.com
# 1. Créer un compte → Vérifier le domaine (enregistrements DNS)
# 2. Générer une clé API et la coller ici
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ANALYTICS ───────────────────────────────────────────────────────────────
# Plausible Analytics — privacy-first, sans cookie, RGPD natif
# Remplacer par votre domaine exact enregistré sur plausible.io
# Le script est déjà intégré dans app/layout.tsx avec data-domain=lesjardinsdelhacienda54.com
# Si vous changez de domaine, mettre aussi à jour le data-domain dans app/layout.tsx
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=lesjardinsdelhacienda54.com

# ── NOTES SÉCURITÉ ──────────────────────────────────────────────────────────
# RESEND_API_KEY, CONTACT_EMAIL et FROM_EMAIL sont des variables SERVEUR.
# Ne jamais les préfixer NEXT_PUBLIC_ — elles resteraient dans le bundle JS public.
# Sur Vercel : Dashboard → Settings → Environment Variables → ajouter chaque variable.
